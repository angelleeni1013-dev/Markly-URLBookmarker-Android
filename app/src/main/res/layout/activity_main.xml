<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:backgroundTint="#FFFFFF"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Blue Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/header_background"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Toolbar with Logo, Title and Kebab Menu -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
                app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

                <!-- Custom Logo and Title Layout -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Logo Icon (on the left) -->

                    <!-- Title and Subtitle -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.9"
                            android:letterSpacing="0.05"
                            android:text="@string/app_tagline"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- Note: Kebab menu will appear here automatically -->

                </LinearLayout>

            </androidx.appcompat.widget.Toolbar>

            <!-- Search and Filter Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Search Bar -->
                <androidx.cardview.widget.CardView
                    android:layout_width="208dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FEFEFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="220dp"
                        android:layout_height="51dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:alpha="0.7"
                            android:contentDescription="@string/search_icon"
                            android:src="@android:drawable/ic_menu_search" />

                        <EditText
                            android:id="@+id/etSearch"
                            android:layout_width="120dp"
                            android:layout_height="match_parent"
                            android:autofillHints="search"
                            android:background="@android:color/transparent"
                            android:hint="@string/search"
                            android:imeOptions="actionSearch"
                            android:importantForAutofill="no"
                            android:inputType="text"
                            android:maxLines="1"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:textColor="#090909"
                            android:textColorHint="#7070A9"
                            android:textSize="14sp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Category Filter Spinner -->
                <androidx.cardview.widget.CardView
                    android:layout_width="120dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="#4D5B9E"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">

                    <Spinner
                        android:id="@+id/spinnerCategoryFilter"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:backgroundTint="#F6F6F6"
                        android:gravity="center"
                        android:popupBackground="@color/background_light"
                        android:spinnerMode="dropdown" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

        <!-- Bookmarks ListView -->
        <ListView
            android:id="@+id/lvBookmarks"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:scrollbarStyle="outsideOverlay" />

    </LinearLayout>

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddBookmark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#3F51B5"
        app:elevation="6dp"
        app:fabSize="normal"
        app:tint="#FFFFFF" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>