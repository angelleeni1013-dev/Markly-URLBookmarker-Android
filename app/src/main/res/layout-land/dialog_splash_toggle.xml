<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    android:backgroundTint="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp">

        <!-- Left Side: Title and Description (60%) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:orientation="vertical"
            android:layout_marginEnd="20dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Splash Screen"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <!-- Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose whether to show the splash screen when the app starts."
                android:textSize="14sp"
                android:textColor="#666666"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- Right Side: Radio and Buttons (40%) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.4"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <!-- Radio Group -->
            <RadioGroup
                android:id="@+id/radioGroupSplash"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F5F5F5"
                android:padding="8dp">

                <RadioButton
                    android:id="@+id/radioEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enabled"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:padding="10dp"
                    android:buttonTint="#3F51B5"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/radioDisabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Disabled"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:padding="10dp"
                    android:buttonTint="#3F51B5" />

            </RadioGroup>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btnCancel"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="Cancel"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:background="?attr/selectableItemBackground"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="Save"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:backgroundTint="#3F51B5"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>