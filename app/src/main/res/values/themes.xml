<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme WITHOUT Action Bar -->
    <style name="Theme.Markly" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">#3F51B5</item>
        <item name="colorPrimaryVariant">#1A237E</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#3F51B5</item>
        <item name="colorSecondaryVariant">#1A237E</item>
    </style>

    <!-- Splash Screen Theme (No Action Bar) -->
    <style name="Theme.Markly.NoActionBar" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">#3F51B5</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>